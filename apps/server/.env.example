# AI Learning Platform - 后端环境配置

# 服务器配置
SERVER_PORT=3000
NODE_ENV=development

# JWT 配置
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Socket.io CORS
SOCKET_IO_CORS_ORIGIN=http://localhost:5173

# 数据库配置 (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/ai_learning
# 或分开配置:
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=password
DATABASE_NAME=ai_learning

# AI 服务配置 (免费 API 优先顺序)
# 1. Groq AI (免费) - https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key

# 2. Google Gemini (免费) - https://makersuite.google.com/app/apikey
GOOGLE_GEMINI_API_KEY=your-google-api-key

# 3. HuggingFace (免费) - https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your-huggingface-token

# 4. 本地 LLM (可选)
LOCAL_LLM_URL=http://localhost:8000/v1

# AI 启用开关
AI_ENABLED=true

# 邮件配置
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
_ENABLED=true

# 备用 AI 服务 (可选)
# OPENAI_API_KEY=sk-your-key-here
# COHERE_API_KEY=cohere-your-key-here

# 邮件配置 (可选)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
