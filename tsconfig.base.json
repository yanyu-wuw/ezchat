{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleResolution": "bundler",
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@ezchat/types": ["packages/types/src"],
      "@ezchat/types/*": ["packages/types/src/*"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["apps", "packages"],
  "references": [
    { "path": "./apps/server" },
    { "path": "./apps/web" },
    { "path": "./packages/types" }
  ]
}
